# FinGenie Frontend Environment
# Copy to .env and configure for your environment

# Shared fallback API base URL (used by web and non-Android local flows)
EXPO_PUBLIC_API_URL=http://localhost:8080

# Optional explicit API URLs by runtime
# Web local
EXPO_PUBLIC_API_URL_WEB=http://localhost:8080
# Android emulator (host machine loopback)
EXPO_PUBLIC_API_URL_ANDROID_EMULATOR=http://10.0.2.2:8080
# Android physical device (replace with your machine LAN IP)
EXPO_PUBLIC_API_URL_ANDROID_DEVICE=http://192.168.1.100:8080

# Google OAuth client IDs
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
# Optional until iOS native Google Sign-In is enabled
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
